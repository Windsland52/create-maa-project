{
    "name": "create-maa-project",
    "version": "0.1.0",
    "type": "module",
    "license": "AGPL-3.0-or-later",
    "bin": {
        "create-maa-project": "./dist/index.js"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/Windsland52/create-maa-project"
    },
    "files": [
        "dist/index.js",
        "templates",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "node scripts/build.mjs",
        "build:sea": "node scripts/build-sea.mjs",
        "dev": "tsx src/index.ts",
        "format": "prettier --write . --ignore-unknown",
        "format:check": "prettier --check . --ignore-unknown",
        "release:manifest": "node scripts/create-release-manifest.mjs",
        "release:prepare-pypi": "node scripts/prepare-pypi-release.mjs",
        "release:sync-version": "node scripts/sync-release-version.mjs",
        "sync:schema": "node scripts/sync-schema.mjs",
        "typecheck": "tsc --noEmit",
        "check:network": "tsx scripts/check-network-assets.ts",
        "pretest": "pnpm build",
        "test": "vitest run && node scripts/test-python.mjs",
        "check": "pnpm format:check && pnpm typecheck && pnpm test"
    },
    "devDependencies": {
        "@nekosu/prettier-plugin-maafw-sort": "1.0.5",
        "@types/node": "24.0.0",
        "esbuild": "0.25.5",
        "postject": "1.0.0-alpha.6",
        "prettier": "3.8.4",
        "prettier-plugin-multiline-arrays": "4.1.9",
        "tsx": "4.20.3",
        "typescript": "5.8.3",
        "vitest": "3.2.4"
    },
    "engines": {
        "node": ">=24"
    },
    "publishConfig": {
        "access": "public"
    },
    "packageManager": "pnpm@11.5.1",
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.29.0"
    }
}
