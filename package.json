{
    "name": "create-maa-project",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "bin": {
        "create-maa-project": "./dist/index.js"
    },
    "files": [
        "dist",
        "templates",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
