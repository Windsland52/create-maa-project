{
    "Default": {
        "rate_limit": 1000,
        "timeout": 20000,
        "pre_delay": 200,
        "post_delay": 200
    },
    "TemplateMatch": {
        // 模板匹配默认参数。
        // Common template matching defaults.
        "recognition": "TemplateMatch",
        "threshold": 0.7,
        "method": 5
    },
    "OCR": {
        // OCR 默认参数。OCR 模型文件从 resource/base/model/ocr 加载。
        // Common OCR defaults. OCR model files are loaded from resource/base/model/ocr.
        "recognition": "OCR",
        "threshold": 0.3,
        "order_by": "Horizontal",
        "replace": []
    },
    "Click": {
        "action": "Click",
        "target": true
    },
    "LongPress": {
        "action": "LongPress",
        "target": true,
        "duration": 1000
    },
    "Swipe": {
        "action": "Swipe",
        "duration": 200
    }
}
